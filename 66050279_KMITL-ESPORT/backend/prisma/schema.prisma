generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id  Int    @id @default(autoincrement())
  username String @unique
  email    String @unique
  password String
  role     String
  teams    Team[]
}

model Team {
  team_id         Int           @id @default(autoincrement())
  team_name       String        @unique
  team_banner_url String?
  leader_name     String
  member_1        String?
  member_2        String?
  member_3        String?
  member_4        String?
  created_by      Int
  applications    Application[]
  creator         User          @relation(fields: [created_by], references: [user_id], onDelete: Cascade)
}

model Tournament {
  tournament_id     Int           @id @default(autoincrement())
  tournament_name   String
  tournament_type   String
  description       String?
  match_date        DateTime?
  start_date        DateTime
  end_date          DateTime
  tournament_banner String?
  age_min           Int?
  age_max           Int?
  duration          String?
  format            String?
  applications      Application[]
  matches           Match[]
}

model Application {
  app_id        Int        @id @default(autoincrement())
  tournament_id Int
  team_id       Int
  status        String     @default("Pending")
  team          Team       @relation(fields: [team_id], references: [team_id])
  tournament    Tournament @relation(fields: [tournament_id], references: [tournament_id])
}

model Match {
  match_id      Int        @id @default(autoincrement())
  tournament_id Int
  team1_name    String?
  team2_name    String?
  score1        Int?
  score2        Int?
  round         Int
  position      Int
  tournament    Tournament @relation(fields: [tournament_id], references: [tournament_id], onDelete: Cascade)
}
