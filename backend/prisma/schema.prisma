generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id  Int    @id @default(autoincrement())
  username String @unique
  email    String @unique
  password String
  role     String

  teams Team[]
}

model Team {
  team_id         Int     @id @default(autoincrement())
  team_name       String  @unique
  team_banner_url String?
  leader_name     String
  member_1        String?
  member_2        String?
  member_3        String?
  member_4        String?

  created_by Int
  creator    User @relation(fields: [created_by], references: [user_id], onDelete: Cascade)

  applications Application[]
}

model Tournament {
  tournament_id   Int      @id @default(autoincrement())
  tournament_name String
  tournament_type String // Single / Double
  start_date      DateTime
  end_date        DateTime

  applications Application[]
}

model Application {
  app_id        Int    @id @default(autoincrement())
  tournament_id Int
  team_id       Int
  status        String @default("Pending")

  tournament Tournament @relation(fields: [tournament_id], references: [tournament_id])
  team       Team       @relation(fields: [team_id], references: [team_id])
}
